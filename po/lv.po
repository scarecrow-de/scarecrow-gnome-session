#: data/io.github.scarecrow_de.SessionManager.gschema.xml.in:5
msgid "Save sessions"
msgstr "Saglabāt sesijas"

#: data/io.github.scarecrow_de.SessionManager.gschema.xml.in:6
msgid "If enabled, scarecrow-session will save the session automatically."
msgstr "Ja ieslēgts, scarecrow-session automātiski saglabās sesiju."

#: data/io.github.scarecrow_de.SessionManager.gschema.xml.in:10
msgid "Save this session"
msgstr "Saglabāt šo sesiju"

#: data/io.github.scarecrow_de.SessionManager.gschema.xml.in:11
msgid ""
"When enabled, scarecrow-session will automatically save the next session at log "
"out even if auto saving is disabled."
msgstr ""
"Kad ieslēgts, scarecrow-session izrakstoties automātiski saglabās nākamo sesiju, "
"pat ja automātiskā saglabāšana ir izslēgta."

#: data/io.github.scarecrow_de.SessionManager.gschema.xml.in:15
msgid "Logout prompt"
msgstr "Izrakstīšanās uzvedne"

#: data/io.github.scarecrow_de.SessionManager.gschema.xml.in:16
msgid "If enabled, scarecrow-session will prompt the user before ending a session."
msgstr "Ja ieslēgts, scarecrow-session vaicās lietotājam pirms sesijas beigšanas."

#: data/io.github.scarecrow_de.SessionManager.gschema.xml.in:20
msgid "Show the fallback warning"
msgstr "Rādīt atkāpšanās brīdinājumu"

#: data/io.github.scarecrow_de.SessionManager.gschema.xml.in:21
msgid ""
"If enabled, scarecrow-session will display a warning dialog after login if the "
"session was automatically fallen back."
msgstr ""
"Ja ieslēgts, scarecrow-session pēc ierakstīšanās rādīs brīdinājumu, ja sesija ir "
"automātiski atkāpusies."

