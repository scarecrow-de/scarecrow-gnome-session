[Unit]
Description=Scarecrow X11 Session
# Avoid default After/Before rules
DefaultDependencies=no

Before=scarecrow-session.target

PartOf=graphical-session.target
RefuseManualStart=yes
RefuseManualStop=yes

# Pull in all X11-specific services the session might depend on
Requires=scarecrow-session-x11-services.target
