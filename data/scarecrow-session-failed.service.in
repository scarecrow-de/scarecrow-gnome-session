[Unit]
Description=Scarecrow Session Failed lockdown screen (user)
OnFailure=scarecrow-session-shutdown.target
OnFailureJobMode=replace-irreversibly
CollectMode=inactive-or-failed

PartOf=scarecrow-session-failed.target

# We could do this, but it requires an intermediate target for OnFailure
# handling, so scarecrow-session-failed checks RUNNING_UNDER_GDM itself
#Conflicts=scarecrow-session@gnome-login.target
# or in the case of GDM and then not passing --allow-logout
#Requisite=scarecrow-session@gnome-login.target

[Service]
Type=simple
ExecStart=@libexecdir@/scarecrow-session-failed --allow-logout
# The fail whale doesn't trigger a shutdown itself, so do it here
ExecStopPost=-@libexecdir@/scarecrow-session-ctl --shutdown
